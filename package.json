{
  "name": "partnermarket-global-crm",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare-native relationship CRM for PartnerMarketGlobal",
  "scripts": {
    "dev": "wrangler dev --var AUTH_MODE:dev --var ENVIRONMENT:development",
    "dev:mock": "node scripts/dev-server.mjs",
    "test": "node --test tests/*.test.mjs",
    "check": "node --check src/worker.js && node --check src/lib/domain.js && node --check public/app.js && node --check scripts/dev-server.mjs",
    "validate": "npm run check && npm test",
    "deploy": "wrangler deploy",
    "db:migrate:local": "wrangler d1 migrations apply partnermarket-crm-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply partnermarket-crm-db --remote",
    "db:seed:local": "wrangler d1 execute partnermarket-crm-db --local --file=migrations/0002_seed_demo.sql",
    "db:seed:remote": "wrangler d1 execute partnermarket-crm-db --remote --file=migrations/0002_seed_demo.sql",
    "cf:types": "wrangler types",
    "configure": "node scripts/configure-cloudflare.mjs"
  },
  "devDependencies": {
    "wrangler": "4.112.0"
  },
  "engines": {
    "node": ">=20"
  }
}
